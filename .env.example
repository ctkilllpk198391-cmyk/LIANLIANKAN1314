# 白羊 wechat_agent · 环境变量示例
# 复制为 .env 后填实际值。.env 不要提交到 git。

# 数据库
BAIYANG_DB_URL=sqlite+aiosqlite:///./data/wechat_agent.db

# === LLM API Keys（至少填 1 个 · 多个则自动启用 hybrid 路由）===
#
# 奥卡姆剃刀：填了哪个才注册哪个 · 没填的不假装存在 · 路由自动降级。
# 第一性原理：客户付钱买"AI 像老板"· prompt + LoRA 是核心 · 模型只是工具。
#
# 推荐优先级：

# 1. MiniMax 极速版（推荐 · 拟人最强）
#    sk-cp-* 自动走国内 Token Plan / 其他走国际 PAYG · 自动检测
#    国内套餐：https://platform.minimaxi.com/user-center/payment/token-plan
#    国际 PAYG：https://platform.minimax.io
MINIMAX_API_KEY=

# 2. 字节豆包 1.5 Pro（拟人 No.2 · 中文极自然）
#    申请：https://console.volcengine.com/ark
DOUBAO_API_KEY=
DOUBAO_ENDPOINT_ID=

# 3. DeepSeek V3.2（询价/订单 · 注册送 ¥10）
#    申请：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 4. 智谱 GLM-5.1（高风险/投诉 · BenchLM 中文第一 · 注册送 ¥18）
#    申请：https://bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# 5. Anthropic Claude Sonnet 4.6（可选 · 国际客户）
ANTHROPIC_API_KEY=

# Phase 7+ 自部署 vLLM 推理服务器 URL（多 LoRA · 客户专属分身）
BAIYANG_VLLM_URL=http://localhost:8000/v1

# Hermes 桥接 mock 开关 · 真接 API 设 false（API key 必须有）
BAIYANG_HERMES_MOCK=true
BAIYANG_HERMES_URL=http://127.0.0.1:8317

# 配置文件路径（可选 · 默认 config/tenants.yaml）
BAIYANG_TENANTS_PATH=./config/tenants.yaml

# 分类器模式：rule | llm | hybrid
BAIYANG_CLASSIFIER=rule

# 日志
LOG_LEVEL=INFO

# Phase 5 微信支付商户（暂留空）
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=

# Phase 4 Sentry 崩溃上报
SENTRY_DSN=
