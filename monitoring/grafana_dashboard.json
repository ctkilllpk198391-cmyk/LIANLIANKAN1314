{
  "title": "白羊 · 全局看板",
  "uid": "baiyang-global",
  "timezone": "Asia/Shanghai",
  "panels": [
    {
      "id": 1,
      "title": "活跃 tenant 数",
      "type": "stat",
      "targets": [{"expr": "count(baiyang_tenant_active == 1)"}]
    },
    {
      "id": 2,
      "title": "今日总采纳率",
      "type": "gauge",
      "targets": [{"expr": "avg(baiyang_acceptance_rate)"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {"steps": [
            {"color": "red", "value": 0},
            {"color": "orange", "value": 0.5},
            {"color": "green", "value": 0.7}
          ]}
        }
      }
    },
    {
      "id": 3,
      "title": "回复生成 p95 延迟",
      "type": "graph",
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(baiyang_generation_latency_seconds_bucket[5m]))"
      }]
    },
    {
      "id": 4,
      "title": "禁用词命中（每小时）",
      "type": "graph",
      "targets": [{"expr": "rate(baiyang_forbidden_word_blocked_total[1h])"}]
    },
    {
      "id": 5,
      "title": "GPU 利用率",
      "type": "graph",
      "targets": [{"expr": "DCGM_FI_DEV_GPU_UTIL"}]
    },
    {
      "id": 6,
      "title": "vLLM LoRA 数",
      "type": "stat",
      "targets": [{"expr": "vllm_loras_loaded"}]
    },
    {
      "id": 7,
      "title": "今日成交（按 tenant）",
      "type": "table",
      "targets": [{"expr": "baiyang_orders_today"}]
    },
    {
      "id": 8,
      "title": "封号事件（24h）",
      "type": "stat",
      "targets": [{"expr": "increase(baiyang_account_banned_total[24h])"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"steps": [
            {"color": "green", "value": 0},
            {"color": "red", "value": 1}
          ]}
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1
}
